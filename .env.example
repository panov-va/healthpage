# HealthPage — пример окружения для dev. Скопируй в .env и заполни значения локально.
# НИКОГДА не коммить .env с реальными значениями (CLAUDE.md §2, INFRASTRUCTURE §0).
# Здесь — только имена переменных и безопасные dev-дефолты.

# --- Общие ---
APP_ENV=dev
HTTP_PORT=8080
BASE_URL=http://localhost:8080

# --- public-ssr (Next.js) ---
# Базовый URL backend-API, к которому SSR ходит за публичной сводкой (server-side).
# В docker-сети: http://api:8080/api/v1; локально: http://localhost:8080/api/v1.
HEALTHPAGE_API_URL=http://localhost:8080/api/v1

# --- PostgreSQL ---
POSTGRES_USER=healthpage
POSTGRES_PASSWORD=healthpage
POSTGRES_DB=healthpage
# Строка подключения для сервисов (host=postgres внутри docker-сети).
DATABASE_URL=postgres://healthpage:healthpage@postgres:5432/healthpage?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=healthpage
RABBITMQ_DEFAULT_PASS=healthpage
RABBITMQ_URL=amqp://healthpage:healthpage@rabbitmq:5672/

# --- Auth (этап 1) ---
# Секрет подписи операторских access-JWT. В проде — длинный случайный секрет, НЕ коммитить.
JWT_SECRET=dev-insecure-change-me
# TTL токенов (Go duration). Дефолты: access 15m, refresh 720h (30d).
# ACCESS_TTL=15m
# REFRESH_TTL=720h

# --- Email / Telegram / MAX / Slack / ЮKassa ---
# Появятся на соответствующих этапах (см. INFRASTRUCTURE.md §3).
